            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.0w4887r1xnyk5w1fd4akm0c1u0gf'>
            <column caption='% Diff Sales' datatype='real' default-format='p0.0%' name='[Calculation_0195247640981505]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='(SUM ([Calculation_4834358872326144])- SUM([Calculation_4834358874951681]))/ SUM([Calculation_4834358874951681])' />
            </column>
            <column caption='Min/ Max Sales' datatype='real' name='[Calculation_0202669350584320]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF SUM([Calculation_4834358872326144]) = WINDOW_MAX(SUM([Calculation_4834358872326144]))&#10;THEN SUM([Calculation_4834358872326144])&#10;&#10;ELSEIF SUM([Calculation_4834358872326144]) = WINDOW_MIN(SUM([Calculation_4834358872326144]))&#10;THEN SUM([Calculation_4834358872326144])&#10;&#10;ELSE NULL&#10;END'>
