              </calculation>
            </column>
            <column caption='CY Sales' datatype='real' name='[Calculation_4834358872326144]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF YEAR([Order Date]) = [Parameters].[Category Parameter] THEN [Sales]&#10;END' />
            </column>
            <column caption='PY Sales' datatype='real' name='[Calculation_4834358874951681]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF YEAR( [Order Date]) = [Parameters].[Category Parameter]- 1 THEN [Sales]&#10;END' />
